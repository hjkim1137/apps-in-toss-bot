# ── 텔레그램 ─────────────────────────────────────────────
# @BotFather 로 봇 생성 후 발급받은 토큰
TELEGRAM_BOT_TOKEN=
# chat id — 명령 화이트리스트 + 다이제스트 수신자 겸용. 여러 명은 쉼표로 (예: 111,222,333)
# 각자 @userinfobot 으로 자기 id 확인 + 각자 봇에게 Start 를 눌러야 수신됨
TELEGRAM_CHAT_ID=
# setWebhook 시 등록하는 secret_token (임의의 긴 랜덤 문자열)
TELEGRAM_WEBHOOK_SECRET=

# ── Supabase (앱별 service role 키 — 서버에서만 사용, 절대 커밋 금지) ──
SAJUMON_SUPABASE_URL=
SAJUMON_SERVICE_ROLE_KEY=
PLNL_SUPABASE_URL=
PLNL_SERVICE_ROLE_KEY=

# ── Threads (선택) ───────────────────────────────────────
# 최초 장기 토큰. 이후 뺄래낼래 Supabase 의 ops_kv 테이블이 자동 관리(갱신)
THREADS_ACCESS_TOKEN=

# ── Vercel Cron 보호 ─────────────────────────────────────
# 이 값을 env 로 설정하면 Vercel cron 이 Authorization: Bearer 로 자동 첨부
CRON_SECRET=
